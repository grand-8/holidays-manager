# =============================================================================
# Variables d'environnement — Application vacances familiales
# =============================================================================
# GABARIT versionné — NE JAMAIS y mettre de vraies valeurs/secrets.
# Copiez ce fichier vers .env.local et renseignez-y les vraies valeurs :
#   cp .env.example .env.local
# .env.local est git-ignoré. En production, renseignez ces variables dans
# Vercel : Project → Settings → Environment Variables.
# =============================================================================

# --- Base de données Neon (PostgreSQL) --------------------------------------
# Dashboard Neon → projet → Connection Details.
# DATABASE_URL : chaîne AVEC pooling (host en "...-pooler..."), pour l'app.
#   Ajoutez &pgbouncer=true à la fin (requis par Prisma avec le pooler Neon).
# DIRECT_URL   : chaîne SANS pooling (connexion directe), pour les migrations.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# --- Resend (envoi d'emails : OTP + notifications) --------------------------
# Créez une clé API dans Resend → API Keys.
# RESEND_FROM_EMAIL doit utiliser un DOMAINE VÉRIFIÉ dans Resend
# (sinon les emails partent en spam ou sont rejetés — spec section 11).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Vacances familiales <noreply@votre-domaine.tld>"

# --- Secret de session ------------------------------------------------------
# Valeur aléatoire d'au moins 32 caractères, pour signer/hacher les sessions.
# Générez-la avec :  openssl rand -base64 48
SESSION_SECRET="a-generer-avec-openssl-rand-base64-48"

# --- URL publique de l'application ------------------------------------------
# En local : http://localhost:3000
# En production : https://votre-domaine.tld
APP_URL="http://localhost:3000"

# --- Relances automatiques (Vercel Cron) ------------------------------------
# Secret protégeant /api/cron/reminders (relances J-7/J-3, section 6).
# Vercel l'ajoute automatiquement à l'en-tête Authorization des appels Cron
# quand il est défini en variable d'environnement. Au moins 16 caractères.
# Générez-le avec :  openssl rand -hex 24
# Absent = la route refuse tout appel (les relances ne partent pas).
CRON_SECRET="a-generer-avec-openssl-rand-hex-24"
