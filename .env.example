# =============================================================================
# Variables d'environnement — Application vacances familiales
# =============================================================================
# Copiez ce fichier vers .env.local (ne JAMAIS committer .env.local).
#   cp .env.example .env.local
# En production, renseignez ces mêmes variables dans Vercel :
#   Project → Settings → Environment Variables.
# =============================================================================

# --- Base de données Neon (PostgreSQL) --------------------------------------
# Dans le dashboard Neon → projet → Connection Details.
# DATABASE_URL : chaîne AVEC pooling (host en "...-pooler..."), pour l'app.
#   Ajoutez ?sslmode=require&pgbouncer=true à la fin.
# DIRECT_URL   : chaîne SANS pooling (connexion directe), pour les migrations.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# --- Resend (envoi d'emails : OTP + notifications) --------------------------
# Créez une clé API dans Resend → API Keys.
# RESEND_FROM_EMAIL doit utiliser un DOMAINE VÉRIFIÉ dans Resend
# (sinon les emails partent en spam ou sont rejetés — spec section 11).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Vacances familiales <noreply@votre-domaine.ch>"

# --- Secret de session ------------------------------------------------------
# Valeur aléatoire d'au moins 32 caractères, pour signer/hacher les sessions.
# Générez-la avec :  openssl rand -base64 48
SESSION_SECRET="remplacez-par-une-valeur-aleatoire-de-48-octets-minimum"

# --- URL publique de l'application ------------------------------------------
# En local : http://localhost:3000
# En production : https://votre-app.vercel.app  (ou votre domaine)
APP_URL="http://localhost:3000"
